# Ignore all campaigns except the kept ones
public/campaigns/*
!public/campaigns/Testing\ G1
!public/campaigns/Testing\ G2
!public/campaigns/Testing\ G3
!public/campaigns/Frostfall
public/campaigns/Testing\ G1/*
public/campaigns/Testing\ G2/*
public/campaigns/Testing\ G3/*
public/campaigns/Frostfall/*
!public/campaigns/Testing\ G1/**
!public/campaigns/Testing\ G2/**
!public/campaigns/Testing\ G3/**
!public/campaigns/Frostfall/**

# Per-campaign character change data (debounced in-memory state)
public/campaigns/*/data/character-change-data.json
public/campaigns/*/data/campaign-log.json

# Campaign snapshots (admin backups)
public/campaigns/.snapshots/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Ignore Vite plugin cache files and test files
**/.vite-plugin-*.json
**/wizard-test-*.json

# Coverage reports
coverage
coverage-report

# Openclaw backups
*openclaw-backup*.tar.gz
coverage-report.txt
