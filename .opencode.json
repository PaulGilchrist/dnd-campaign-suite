{
    "$schema": "https://opencode.ai/config.json",
    "autoupdate": true,
    "default_agent": "orchestrator",
    "instructions": [
        "RULES.md"
    ],
    "mcp": {
        "chrome-devtools": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "chrome-devtools-mcp@latest"
            ],
            "enabled": true,
            "timeout": 30000
        }
    }
}