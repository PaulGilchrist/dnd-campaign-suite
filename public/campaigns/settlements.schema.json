{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Settlement Schema",
    "description": "Schema for D&D Settlement data",
    "type": "array",
    "items": {
        "type": "object",
        "required": [
            "name"
        ],
        "properties": {
            "name": {
                "type": "string",
                "description": "The settlement's name (unique)"
            },
            "size": {
                "type": "string",
                "enum": ["village", "town", "city", "metropolis"],
                "description": "Settlement size category"
            },
            "description": {
                "type": "string",
                "description": "Description of the settlement"
            },
            "atmosphere": {
                "type": "string",
                "description": "Ambiance and mood of the settlement"
            },
            "government": {
                "type": "string",
                "description": "Governance structure"
            },
            "population": {
                "type": "string",
                "description": "Approximate population"
            },
            "services": {
                "type": "array",
                "items": {
                    "type": "object",
                    "properties": {
                        "type": {"type": "string"},
                        "name": {"type": "string"},
                        "description": {"type": "string"}
                    }
                },
                "description": "Available services in the settlement"
            },
            "notableNPCs": {
                "type": "array",
                "items": {
                    "type": "object",
                    "properties": {
                        "name": {"type": "string"},
                        "role": {"type": "string"},
                        "description": {"type": "string"}
                    }
                },
                "description": "Notable NPCs associated with the settlement"
            },
            "rumors": {
                "type": "array",
                "items": {"type": "string"},
                "description": "Current news and rumors"
            },
            "tags": {
                "type": "string",
                "description": "Comma-separated tags for categorization"
            },
            "notes": {
                "type": "string",
                "description": "Additional GM notes"
            },
            "image": {
                "type": "string",
                "description": "Base64 image data (client-side only)"
            },
            "imageName": {
                "type": "string",
                "description": "Original image filename"
            }
        }
    }
}
