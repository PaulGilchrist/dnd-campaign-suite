{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Indoor Map Schema",
    "description": "Schema for D&D indoor map data",
    "type": "object",
    "required": [
        "displayName",
        "gridSize",
        "walls",
        "placedItems",
        "players",
        "zoom",
        "panX",
        "panY",
        "fog"
    ],
    "properties": {
        "name": {
            "type": "string",
            "description": "The map name (defaults to file name if not set)"
        },
        "displayName": {
            "type": "string",
            "description": "Human-readable display name for the map"
        },
        "description": {
            "type": "string",
            "description": "Markdown description of the map"
        },
        "gridSize": {
            "type": "integer",
            "minimum": 5,
            "maximum": 100,
            "description": "Grid dimension in cells"
        },
        "walls": {
            "type": "array",
            "items": {
                "type": "string",
                "pattern": "^\\d+,\\d+$"
            },
            "description": "Array of 'x,y' coordinate strings for wall cells"
        },
        "placedItems": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "id",
                    "gridX",
                    "gridY",
                    "type",
                    "visible"
                ],
                "properties": {
                    "id": {
                        "type": "string",
                        "description": "Unique identifier for the placed item"
                    },
                    "gridX": {
                        "type": "integer",
                        "description": "Grid column position"
                    },
                    "gridY": {
                        "type": "integer",
                        "description": "Grid row position"
                    },
                    "type": {
                        "type": "string",
                        "enum": [
                            "altar",
                            "arrowSlitWall",
                            "bed",
                            "bookshelf",
                            "chair",
                            "chest",
                            "crate",
                            "door",
                            "firepit",
                            "fountain",
                            "npc",
                            "pillar",
                            "secretDoor",
                            "stairs",
                            "statue",
                            "table",
                            "torch",
                            "trap",
                            "web",
                            "tree",
                            "boulder",
                            "bush"
                        ],
                        "description": "The type of placed item.  Note: npc represents a monster of other non-player character type and should have name property set to exactly match the name in the Monster Manual for proper image lookup"
                    },
                    "visible": {
                        "type": "boolean",
                        "description": "Whether the item is visible"
                    },
                    "rotation": {
                        "type": "integer",
                        "enum": [
                            0,
                            90,
                            180,
                            270
                        ],
                        "description": "Rotation in degrees"
                    },
                    "name": {
                        "type": "string",
                        "description": "Display name for NPC tokens"
                    }
                }
            },
            "description": "Array of placed map tokens"
        },
        "players": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "id",
                    "name",
                    "gridX",
                    "gridY"
                ],
                "properties": {
                    "id": {
                        "type": "string",
                        "description": "Unique identifier for the player"
                    },
                    "name": {
                        "type": "string",
                        "description": "Player name"
                    },
                    "gridX": {
                        "type": "integer",
                        "description": "Grid column position"
                    },
                    "gridY": {
                        "type": "integer",
                        "description": "Grid row position"
                    }
                }
            },
            "description": "Array of player tokens"
        },
        "zoom": {
            "type": "number",
            "description": "Zoom level"
        },
        "panX": {
            "type": "number",
            "description": "Horizontal pan offset"
        },
        "panY": {
            "type": "number",
            "description": "Vertical pan offset"
        },
        "fog": {
            "type": "array",
            "items": {
                "type": "string",
                "pattern": "^\\d+,\\d+$"
            },
            "description": "Array of 'x,y' strings for fog-of-war cells"
        },
        "rooms": {
            "type": "array",
            "description": "Persistent room metadata for room-aware operations",
            "items": {
                "type": "object",
                "required": ["id", "rect"],
                "properties": {
                    "id": {
                        "type": "integer",
                        "description": "Unique room identifier"
                    },
                    "rect": {
                        "type": "object",
                        "required": ["x", "y", "w", "h"],
                        "properties": {
                            "x": { "type": "integer" },
                            "y": { "type": "integer" },
                            "w": { "type": "integer", "minimum": 1 },
                            "h": { "type": "integer", "minimum": 1 }
                        },
                        "description": "Bounding rectangle of the room"
                    },
                    "type": {
                        "type": "string",
                        "enum": ["entrance", "common", "utility", "private", "grand", "hall", "passage"],
                        "description": "Room type for furnishing and labeling"
                    },
                    "label": {
                        "type": "string",
                        "description": "Human-readable room label (e.g. 'Throne Room')"
                    },
                    "connectedTo": {
                        "type": "array",
                        "items": { "type": "integer" },
                        "description": "IDs of rooms directly connected to this room"
                    },
                    "vertices": {
                        "type": "array",
                        "description": "Future: polygon vertices for irregular room shapes (replaces rect when set)",
                        "items": {
                            "type": "object",
                            "properties": {
                                "x": { "type": "number" },
                                "y": { "type": "number" }
                            }
                        }
                    },
                    "notes": {
                        "type": "string",
                        "description": "DM notes attached to this room"
                    }
                }
            }
        }
    }
}