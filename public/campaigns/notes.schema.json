{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Notes Schema",
    "description": "Schema for D&D campaign notes",
    "type": "array",
    "items": {
        "type": "object",
        "required": [
            "id",
            "description",
            "isPrivate",
            "dateCreated",
            "dateModified"
        ],
        "properties": {
            "id": {
                "type": "string",
                "format": "uuid",
                "description": "Unique identifier for the note"
            },
            "description": {
                "type": "string",
                "description": "The content of the note"
            },
            "isPrivate": {
                "type": "boolean",
                "description": "Whether the note is private to the GM"
            },
            "dateCreated": {
                "type": "string",
                "format": "date-time",
                "description": "ISO timestamp when the note was created"
            },
            "dateModified": {
                "type": "string",
                "format": "date-time",
                "description": "ISO timestamp when the note was last modified"
            },
            "partyLevel": {
                "type": "integer",
                "minimum": 1,
                "maximum": 20,
                "description": "Average party level at the time of the note"
            },
            "partyLocation": {
                "type": "string",
                "description": "Current party location when the note was made"
            }
        }
    }
}
