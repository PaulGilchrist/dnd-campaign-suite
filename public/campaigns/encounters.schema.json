{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Encounter Schema",
    "description": "Schema for D&D encounter data",
    "type": "object",
    "required": [
        "encounters"
    ],
    "properties": {
        "encounters": {
            "type": "array",
            "description": "Array of saved encounters",
            "items": {
                "type": "object",
                "required": [
                    "name",
                    "playerLevels",
                    "selectedMonsters"
                ],
                "properties": {
                    "name": {
                        "type": "string",
                        "description": "The encounter's name"
                    },
                    "description": {
                        "type": "string",
                        "description": "A markdown description of the encounter"
                    },
                    "savedAt": {
                        "type": "string",
                        "format": "date-time",
                        "description": "ISO timestamp when the encounter was saved"
                    },
                    "rulesVersion": {
                        "type": "string",
                        "enum": [
                            "5e",
                            "2024"
                        ],
                        "description": "Rule system version used (e.g., '5e', '2024')"
                    },
                    "difficulty": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 3,
                        "description": "Encounter difficulty: 0=Easy, 1=Medium, 2=Hard, 3=Deadly"
                    },
                    "playerLevels": {
                        "type": "array",
                        "items": {
                            "type": "integer",
                            "minimum": 1,
                            "maximum": 20
                        },
                        "description": "Array of player character levels"
                    },
                    "selectedMonsters": {
                        "type": "array",
                        "description": "Array of monster references",
                        "items": {
                            "type": "object",
                            "required": [
                                "index",
                                "name",
                                "qty"
                            ],
                            "properties": {
                                "index": {
                                    "type": "string",
                                    "description": "The monster's index identifier"
                                },
                                "name": {
                                    "type": "string",
                                    "description": "The monster's name"
                                },
                                "qty": {
                                    "type": "integer",
                                    "minimum": 1,
                                    "description": "Quantity of this monster in the encounter"
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}