{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Outdoor Map Schema",
    "description": "Schema for D&D outdoor hex map data",
    "type": "object",
    "required": [
        "type",
        "gridSize",
        "terrain",
        "pois",
        "zoom",
        "panX",
        "panY"
    ],
    "properties": {
        "type": {
            "type": "string",
            "enum": [
                "outdoor"
            ],
            "description": "Map type identifier"
        },
        "description": {
            "type": "string",
            "description": "Markdown description of the map"
        },
        "gridSize": {
            "type": "integer",
            "minimum": 5,
            "maximum": 100,
            "description": "Hex grid dimension in pixels"
        },
        "terrain": {
            "type": "object",
            "description": "Mapping of hex coordinates to terrain types",
            "additionalProperties": {
                "type": "string",
                "enum": [
                    "beach",
                    "desert",
                    "forest",
                    "hills",
                    "mountains",
                    "plains",
                    "swamp",
                    "tundra",
                    "water"
                ]
            },
            "propertyNames": {
                "pattern": "^[0-9]+,[0-9]+$"
            }
        },
        "rivers": {
            "type": "array",
            "description": "Hex coordinates that rivers flow through",
            "items": {
                "type": "string",
                "pattern": "^[0-9]+,[0-9]+$"
            }
        },
        "pois": {
            "type": "array",
            "description": "Array of points of interest on the map",
            "items": {
                "type": "object",
                "required": [
                    "id",
                    "type",
                    "q",
                    "r",
                    "visible",
                    "label"
                ],
                "properties": {
                    "id": {
                        "type": "string",
                        "description": "Unique identifier for the point of interest"
                    },
                    "type": {
                        "type": "string",
                        "enum": [
                            "camp",
                            "city",
                            "dungeon",
                            "hazard",
                            "landmark",
                            "loreSite",
                            "naturalWonder",
                            "settlement",
                            "tower"
                        ],
                        "description": "Category of the point of interest"
                    },
                    "q": {
                        "type": "integer",
                        "description": "Hex axial column coordinate"
                    },
                    "r": {
                        "type": "integer",
                        "description": "Hex axial row coordinate"
                    },
                    "visible": {
                        "type": "boolean",
                        "description": "Whether the point of interest is visible on the map"
                    },
                    "label": {
                        "type": "string",
                        "description": "Display name for the point of interest"
                    }
                }
            }
        },
        "zoom": {
            "type": "number",
            "description": "Current zoom level of the map view"
        },
        "panX": {
            "type": "number",
            "description": "Horizontal pan offset of the map view"
        },
        "panY": {
            "type": "number",
            "description": "Vertical pan offset of the map view"
        },
        "marchingOrder": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "description": "Characters in marching order by name"
        },
        "weather": {
            "type": "object",
            "description": "Current weather conditions affecting travel",
            "properties": {
                "condition": {
                    "type": "string",
                    "enum": ["clear", "cloudy", "rain", "storm", "fog", "wind", "snow", "mist", "extreme"],
                    "description": "Weather condition identifier"
                },
                "label": { "type": "string" },
                "icon": { "type": "string" },
                "visibility": { "type": ["number", "null"], "description": "Visibility limit in hexes, null = unlimited" },
                "moveCostMod": { "type": ["number", "null"], "description": "Terrain cost multiplier" },
                "budgetMod": { "type": "number", "description": "Daily budget multiplier" },
                "encounterMod": { "type": "number", "description": "Encounter chance modifier" },
                "description": { "type": "string" }
            }
        },
        "partyPosition": {
            "type": "object",
            "properties": {
                "hexQ": {
                    "type": "integer",
                    "description": "Hex axial column coordinate"
                },
                "hexR": {
                    "type": "integer",
                    "description": "Hex axial row coordinate"
                }
            },
            "description": "Current party position on the hex grid"
        }
    }
}
