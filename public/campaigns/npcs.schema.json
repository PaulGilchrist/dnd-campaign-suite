{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "NPC Schema",
    "description": "Schema for D&D NPC data",
    "type": "array",
    "items": {
        "type": "object",
        "required": [
            "name"
        ],
        "properties": {
            "name": {
                "type": "string",
                "description": "The NPC's name"
            },
            "race": {
                "type": "string",
                "description": "The NPC's race (e.g., 'Human', 'Elf', 'Dwarf', 'Halfling')"
            },
            "classRole": {
                "type": "string",
                "description": "The NPC's class or role (e.g., 'Armor Smith', 'Blacksmith', 'Innkeeper')"
            },
            "appearance": {
                "type": "string",
                "description": "Physical description of the NPC"
            },
            "personality": {
                "type": "string",
                "description": "Personality traits, ideals, bonds, and flaws"
            },
            "goals": {
                "type": "string",
                "description": "What the NPC wants or strives for"
            },
            "secrets": {
                "type": "string",
                "description": "Hidden truths about the NPC"
            },
            "notes": {
                "type": "string",
                "description": "Additional notes about the NPC"
            },
            "tags": {
                "type": "string",
                "description": "Comma-separated tags for categorization"
            },
            "attitude": {
                "type": "string",
                "enum": [
                    "deep bonds",
                    "positive",
                    "neutral",
                    "negative",
                    "extreme opposition"
                ],
                "description": "The NPC's attitude toward the character"
            },
            "imagePath": {
                "type": "string",
                "description": "Path to the NPC's avatar image"
            },
            "armorClass": {
                "type": ["integer", "null"],
                "minimum": 0,
                "description": "The NPC's armor class"
            },
            "hitPoints": {
                "type": "string",
                "description": "The NPC's hit points (can be a number or expression)"
            },
            "hitDice": {
                "type": "string",
                "description": "The NPC's hit dice (e.g., '2d8+4')"
            },
            "initiativeBonus": {
                "type": "string",
                "description": "The NPC's initiative bonus (can be empty string if not set)"
            },
            "speed": {
                "type": "object",
                "description": "The NPC's movement speeds",
                "properties": {
                    "walk": {
                        "type": "string"
                    },
                    "fly": {
                        "type": "string"
                    },
                    "swim": {
                        "type": "string"
                    },
                    "climb": {
                        "type": "string"
                    },
                    "burrow": {
                        "type": "string"
                    }
                }
            },
            "abilityScores": {
                "type": "object",
                "description": "The NPC's six ability scores",
                "properties": {
                    "str": { "type": "integer", "minimum": 1, "maximum": 30 },
                    "dex": { "type": "integer", "minimum": 1, "maximum": 30 },
                    "con": { "type": "integer", "minimum": 1, "maximum": 30 },
                    "int": { "type": "integer", "minimum": 1, "maximum": 30 },
                    "wis": { "type": "integer", "minimum": 1, "maximum": 30 },
                    "cha": { "type": "integer", "minimum": 1, "maximum": 30 }
                }
            },
            "savingThrowBonuses": {
                "type": "object",
                "description": "Ability-specific saving throw bonuses",
                "additionalProperties": {
                    "type": "integer"
                }
            },
            "skillBonuses": {
                "type": "object",
                "description": "Skill-specific bonuses (e.g., { perception: 5 })",
                "additionalProperties": {
                    "type": "integer"
                }
            },
            "damageResistances": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Damage types the NPC resists"
            },
            "damageImmunities": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Damage types the NPC is immune to"
            },
            "conditionImmunities": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Conditions the NPC is immune to"
            },
            "actions": {
                "type": "array",
                "items": {
                    "type": "object",
                    "properties": {
                        "name": { "type": "string" },
                        "desc": { "type": "string" }
                    }
                },
                "description": "Actions the NPC can take"
            },
            "traits": {
                "type": "string",
                "description": "Special traits and features of the NPC"
            },
            "reactions": {
                "type": "string",
                "description": "Reactions the NPC can take"
            }
        }
    }
}
